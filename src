void actualizarMinijuego() {
  if (!modoMinijuego) return;

  unsigned long ahora = millis();
  if (ahora - tiempoJuego < VELOCIDAD_GOTA) return;
  tiempoJuego = ahora;

  // Borrar frame anterior
  dibujarFondoPlaceholder(estadoActual);

  // Controles
  if (digitalRead(BTN_A) == LOW && juegoPlantaX > 26)   juegoPlantaX -= 4;
  if (digitalRead(BTN_C) == LOW && juegoPlantaX < 134)  juegoPlantaX += 4;
  if (botonPresionado(1, BTN_B)) { terminarMinijuego(); return; }

  juegoGotaY += 3;

  // Dibujar personaje con sprite
  dibujarSpritePROGMEM(frames_normal_idle[frameActual], juegoPlantaX - SW/2, 95 - SH, SW, SH);

  dibujarGota(juegoGotaX, juegoGotaY);

  // Marcador
  tft.fillRect(0, 0, 120, 14, 0x0000);
  tft.setTextColor(C_AMARILLO); tft.setTextSize(1);
  tft.setCursor(3, 3);
  tft.print("Gotas: "); tft.print(juegoPuntos);
  tft.print("/"); tft.print(gotasTotales);

  if (juegoGotaY >= 115 - SH) {
    gotasTotales++;

    if (abs(juegoGotaX - juegoPlantaX) < 22) {
      juegoPuntos++;
    }

    juegoGotaX = random(15, 145);
    juegoGotaY = 5;

    if (gotasTotales >= 10) { terminarMinijuego(); return; }
  }
}
