void setup() {
  Serial.begin(115200);

  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  tft.fillScreen(0x0000);

  tft.setTextColor(0xFFE0); tft.setTextSize(1);
  tft.setCursor(18, 40); tft.println("Tamagotchi Planta");
  tft.setTextColor(0xFFFF);
  tft.setCursor(30, 58); tft.println("Conectando WiFi...");

  pinMode(12, INPUT_PULLUP);
  pinMode(13, INPUT_PULLUP);
  pinMode(14, INPUT_PULLUP);

  conectarWiFi();

  leerSensor();
  cambiarAnimacion(idleDeEstado(estadoActual));
  dibujarFondoPlaceholder(estadoActual);
  dibujarFrameActual();
  dibujarUI();
}

void loop() {
  unsigned long ahora = millis();

  if (ahora - tiempoSensor >= 5000) {
    tiempoSensor = ahora;
    leerSensor();
  }

  if (tickAnimacion()) {
    dibujarFondoPlaceholder(estadoActual);
    dibujarFrameActual();
    dibujarUI();
  }

  bool enAccion = (animActual == ANIM_COMER);

  if (!enAccion && !modoMinijuego && !enInteraccionSostenida) {
    if (botonPresionado(0, BTN_A)) procesarBotonA();
    if (botonPresionado(1, BTN_B)) procesarBotonB();
    if (botonPresionado(2, BTN_C)) iniciarMinijuego();
  } else if (enInteraccionSostenida) {
    if (botonSuelto(1, BTN_B)) {
      terminarInteraccion();
    } else {
      actualizarBoton(1, BTN_B);
    }
    actualizarBoton(0, BTN_A);
    actualizarBoton(2, BTN_C);
  } else if (enAccion) {
    actualizarBoton(0, BTN_A);
    actualizarBoton(1, BTN_B);
    actualizarBoton(2, BTN_C);
  } else if (modoMinijuego) {
    actualizarMinijuego();
  }
}

void conectarWiFi() {
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int intentos = 0;
  while (WiFi.status() != WL_CONNECTED && intentos < 20) {
    delay(500);
    intentos++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    wifiConectado = true;
    clienteSeguro.setInsecure();
    tft.setCursor(30, 76);
    tft.setTextColor(C_VERDE); tft.setTextSize(1);
    tft.println("WiFi conectado!");
    delay(800);
    enviarTelegram("Sproutchi iniciado! Estoy vigilando tu planta.");
  } else {
    wifiConectado = false;
    tft.setCursor(18, 76);
    tft.setTextColor(C_ROJO); tft.setTextSize(1);
    tft.println("Sin WiFi");
    delay(1500);
  }
}

void enviarTelegram(const char* mensaje) {
  if (!wifiConectado || WiFi.status() != WL_CONNECTED) return;
  bot.sendMessage(CHAT_ID, mensaje, "");
  Serial.print("Telegram: "); Serial.println(mensaje);
}

void leerSensor() {
  int lectura = analogRead(PIN_SENSOR);
  Serial.print("Sensor: "); Serial.println(lectura);
  actualizarEstado(lectura);
}

void actualizarEstado(int lectura) {
  estadoAnterior = estadoActual;

  if      (lectura > UMBRAL_SECO)                                        estadoActual = TRISTE;
  else if (lectura >= UMBRAL_NORMAL_MIN && lectura <= UMBRAL_NORMAL_MAX) estadoActual = NORMAL;
  else if (lectura >= UMBRAL_FELIZ_MIN  && lectura <= UMBRAL_FELIZ_MAX)  estadoActual = FELIZ;
  else if (lectura < UMBRAL_INUNDADO)                                    estadoActual = INUNDADO;
  else                                                                   estadoActual = NORMAL;

  if (estadoActual != estadoAnterior) {
    dibujarPantalla();
    cambiarAnimacion(idleDeEstado(estadoActual));

    unsigned long ahora = millis();
    if (ahora - tiempoUltimaNotif >= INTERVALO_NOTIF) {
      if (estadoActual == TRISTE) {
        enviarTelegram("ALERTA: Tengo sed! dame agua!");
        tiempoUltimaNotif = ahora;
      } else if (estadoActual == INUNDADO) {
        enviarTelegram("ALERTA: Me estoy ahogando! quitame agua!");
        tiempoUltimaNotif = ahora;
      }
    }
  }
}

