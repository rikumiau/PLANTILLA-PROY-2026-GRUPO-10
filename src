bool estadoBoton[3]    = {HIGH, HIGH, HIGH};
bool botonAnterior[3]  = {HIGH, HIGH, HIGH};

bool botonPresionado(int idx, int pin) {
  botonAnterior[idx] = estadoBoton[idx];
  estadoBoton[idx]   = digitalRead(pin);
  if (botonAnterior[idx] == HIGH && estadoBoton[idx] == LOW) {
    delay(30);
    if (digitalRead(pin) == LOW) return true;
  }
  return false;
}

bool botonSuelto(int idx, int pin) {
  botonAnterior[idx] = estadoBoton[idx];
  estadoBoton[idx]   = digitalRead(pin);
  return (botonAnterior[idx] == LOW && estadoBoton[idx] == HIGH);
}

void actualizarBoton(int idx, int pin) {
  botonAnterior[idx] = estadoBoton[idx];
  estadoBoton[idx]   = digitalRead(pin);
}

struct Animacion {
  uint8_t  numFrames;
  uint16_t msPerFrame;
  bool     loop;
  AnimID   animAlTerminar;
};

const Animacion ANIMS[] = {
  {  2,   200,  true,  ANIM_IDLE_TRISTE   },  // triste_idle
  {  2,   400,  true,  ANIM_IDLE_NORMAL   },  // normal_idle
  {  2,   200,  true,  ANIM_IDLE_FELIZ    },  // feliz_idle
  {  2,   150,  true,  ANIM_IDLE_INUNDADO },  // inundado_idle
  {  3,   350,  false, ANIM_IDLE_FELIZ    },  // comer — 3 frames
  {  2,   350,  true,  ANIM_IDLE_FELIZ    },  // cantar — 2 frames
  {  2,   350,  true,  ANIM_IDLE_FELIZ    },  // bailar — 2 frames
  {  2,   500,  true,  ANIM_IDLE_NORMAL   },  // historia — 2 frames
  {  2,   300,  true,  ANIM_JUEGO_IDLE    },  // juego_idle
  {  2,    80,  false, ANIM_JUEGO_IDLE    },  // juego_atrapar — 2 frames
  {  2,   150,  false, ANIM_JUEGO_IDLE    },  // juego_fallar
};

AnimID animActual  = ANIM_IDLE_NORMAL;
int    frameActual = 0;
unsigned long tiempoUltimoFrame = 0;
bool enInteraccionSostenida = false;

void cambiarAnimacion(AnimID nueva) {
  animActual  = nueva;
  frameActual = 0;
  tiempoUltimoFrame = millis();
}

AnimID idleDeEstado(Estado e) {
  switch (e) {
    case TRISTE:   return ANIM_IDLE_TRISTE;
    case NORMAL:   return ANIM_IDLE_NORMAL;
    case FELIZ:    return ANIM_IDLE_FELIZ;
    case INUNDADO: return ANIM_IDLE_INUNDADO;
  }
  return ANIM_IDLE_NORMAL;
}

bool tickAnimacion() {
  unsigned long ahora = millis();
  const Animacion& a  = ANIMS[(int)animActual];
  if (ahora - tiempoUltimoFrame < a.msPerFrame) return false;
  tiempoUltimoFrame = ahora;
  frameActual++;
  if (frameActual >= a.numFrames) {
    if (a.loop) {
      frameActual = 0;
    } else {
      frameActual = a.numFrames - 1;
      cambiarAnimacion(a.animAlTerminar);
    }
  }
  return true;
}

