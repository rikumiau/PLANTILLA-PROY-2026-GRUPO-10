  tft.setCursor(10, 76);
  if      (juegoPuntos >= 9) { tft.setTextColor(C_AMARILLO); tft.println("   PERFECTA!!! :D"); }
  else if (juegoPuntos >= 7) { tft.setTextColor(C_VERDE);    tft.println("   Muy bien! :)");   }
  else if (juegoPuntos >= 4) { tft.setTextColor(C_BLANCO);   tft.println("   Bien! sigue!");   }
  else                       { tft.setTextColor(C_ROJO);     tft.println("   Intenta de nuevo!");}

  delay(3500);
  cambiarAnimacion(idleDeEstado(estadoActual));
  dibujarPantalla();
}
