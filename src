void dibujarFrameActual() {
  const uint16_t* const* framesPtr;
  switch (animActual) {
    case ANIM_IDLE_TRISTE:   framesPtr = frames_triste_idle;   break;
    case ANIM_IDLE_NORMAL:   framesPtr = frames_normal_idle;   break;
    case ANIM_IDLE_FELIZ:    framesPtr = frames_feliz_idle;    break;
    case ANIM_IDLE_INUNDADO: framesPtr = frames_inundado_idle; break;
    case ANIM_COMER:         framesPtr = frames_comer;         break;
    case ANIM_CANTAR:        framesPtr = frames_cantar;        break;
    case ANIM_BAILAR:        framesPtr = frames_bailar;        break;
    case ANIM_HISTORIA:      framesPtr = frames_historia;      break;
    case ANIM_JUEGO_IDLE:    framesPtr = frames_juego_idle;    break;
    case ANIM_JUEGO_ATRAPAR: framesPtr = frames_juego_atrapar; break;
    case ANIM_JUEGO_FALLAR:  framesPtr = frames_juego_fallar;  break;
    default:                 framesPtr = frames_normal_idle;   break;
  }
  dibujarSpritePROGMEM(framesPtr[frameActual], SPX, SPY, SW, SH);
}

void dibujarSpritePROGMEM(const uint16_t* sprite, int x, int y, int w, int h) {
  for (int i = 0; i < w * h; i++) {
    uint16_t color = pgm_read_word(&sprite[i]);
    if (color != C_TRANSP) {
      tft.drawPixel(x + (i % w), y + (i / w), color);
    }
  }
}

